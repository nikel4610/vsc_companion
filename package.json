{
  "name": "vsc-companion",
  "displayName": "Code Companion",
  "description": "A personal VSCode companion for work habits, reminders, and project routines.",
  "version": "0.0.1",
  "publisher": "nikel4610",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:codeCompanion.view",
    "onView:codeCompanion.panelView",
    "onCommand:codeCompanion.open",
    "onCommand:codeCompanion.openBottom",
    "onCommand:codeCompanion.createConfig",
    "onCommand:codeCompanion.openConfigFolder"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codeCompanion",
          "title": "Code Companion",
          "icon": "media/companion.svg"
        }
      ],
      "panel": [
        {
          "id": "codeCompanionPanel",
          "title": "Code Companion",
          "icon": "media/companion.svg"
        }
      ]
    },
    "views": {
      "codeCompanion": [
        {
          "id": "codeCompanion.view",
          "name": "Companion",
          "type": "webview"
        }
      ],
      "codeCompanionPanel": [
        {
          "id": "codeCompanion.panelView",
          "name": "Companion",
          "type": "webview"
        }
      ]
    },
    "configuration": {
      "title": "Code Companion",
      "properties": {
        "codeCompanion.characterName": {
          "type": "string",
          "default": "Companion",
          "description": "Name displayed in the companion panel."
        },
        "codeCompanion.characterPath": {
          "type": "string",
          "default": "",
          "description": "Workspace-relative or absolute image path displayed in the companion panel."
        },
        "codeCompanion.tone": {
          "type": "string",
          "enum": ["calm", "strict", "light"],
          "default": "calm",
          "description": "Message tone used by the companion."
        },
        "codeCompanion.warnDirtyFilesOver": {
          "type": "number",
          "default": 8,
          "minimum": 1,
          "description": "Show a stronger reminder when changed files exceed this number."
        },
        "codeCompanion.remindCommitAfterChangedFiles": {
          "type": "number",
          "default": 5,
          "minimum": 1,
          "description": "Show a commit checklist reminder when changed files reach this number."
        },
        "codeCompanion.remindTestAfterMinutes": {
          "type": "number",
          "default": 120,
          "minimum": 1,
          "description": "Show a test reminder when the last test run is older than this many minutes."
        },
        "codeCompanion.showWorkTimeAfterMinutes": {
          "type": "number",
          "default": 60,
          "minimum": 1,
          "description": "Show a work session reminder after this many minutes."
        },
        "codeCompanion.ambientMotion": {
          "type": "boolean",
          "default": true,
          "description": "Play subtle companion idle motions in the panel."
        },
        "codeCompanion.commands": {
          "type": "array",
          "default": [],
          "description": "Project commands displayed as buttons in the companion panel.",
          "items": {
            "type": "object",
            "required": [
              "label",
              "command"
            ],
            "properties": {
              "label": {
                "type": "string",
                "description": "Button label."
              },
              "command": {
                "type": "string",
                "description": "Shell command to run in a VSCode terminal."
              }
            }
          }
        }
      }
    },
    "commands": [
      {
        "command": "codeCompanion.open",
        "title": "Code Companion: Open Sidebar"
      },
      {
        "command": "codeCompanion.openBottom",
        "title": "Code Companion: Open Bottom Panel"
      },
      {
        "command": "codeCompanion.refresh",
        "title": "Code Companion: Refresh"
      },
      {
        "command": "codeCompanion.createConfig",
        "title": "Code Companion: Create Config"
      },
      {
        "command": "codeCompanion.openConfigFolder",
        "title": "Code Companion: Open Config Folder"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "test": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/vscode": "^1.90.0",
    "@typescript-eslint/eslint-plugin": "^7.15.0",
    "@typescript-eslint/parser": "^7.15.0",
    "eslint": "^8.57.0",
    "typescript": "^5.5.3"
  }
}
